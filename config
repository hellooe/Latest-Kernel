CONFIG_AF_RXRPC=n
CONFIG_MPLS=n
CONFIG_6LOWPAN=n
CONFIG_IEEE802154=n
CONFIG_NFC=n

#
# Network device drivers (full cloud + physical coverage)
#
CONFIG_NET_VENDOR_INTEL=y
CONFIG_E1000E=y
CONFIG_IGB=y
CONFIG_IXGBE=y
CONFIG_I40E=y
CONFIG_ICE=y
CONFIG_VIRTIO_NET=y
CONFIG_VMXNET3=m
CONFIG_NET_VENDOR_MELLANOX=y
CONFIG_MLX5_CORE=y
CONFIG_NET_VENDOR_BROADCOM=y
CONFIG_TIGON3=y
CONFIG_NET_VENDOR_AMAZON=y
CONFIG_ENA_ETHERNET=m
CONFIG_NET_VENDOR_GOOGLE=y
CONFIG_GVE=m
CONFIG_XEN_NETDEV_FRONTEND=m
CONFIG_HYPERV_NET=m

#
# Block devices
#
