# Disable 32-bit emulation
#
CONFIG_IA32_EMULATION=n
CONFIG_X86_X32_ABI=n

#
# kexec support
#
CONFIG_KEXEC=y
CONFIG_KEXEC_FILE=y
CONFIG_CRASH_DUMP=n

#
# Peripherals (keep minimal console, disable others)
#
CONFIG_USB_SUPPORT=n
CONFIG_SERIO=n
CONFIG_INPUT=n
CONFIG_VT=y
CONFIG_DRM=n
CONFIG_FB=n
CONFIG_SOUND=n
CONFIG_HID=n
CONFIG_MMC=n
CONFIG_PCCARD=n
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y