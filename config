CONFIG_SATA_AHCI=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI=y
CONFIG_SCSI_DMA=y
CONFIG_XEN_BLKDEV_FRONTEND=m
CONFIG_HYPERV_STORAGE=m
