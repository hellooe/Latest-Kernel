CONFIG_CDROM=n

#
# I/O schedulers & write-back throttling
#
CONFIG_BFQ=m
CONFIG_MQ_IOSCHED_DEADLINE=y
CONFIG_DEFAULT_DEADLINE=y
CONFIG_BLK_DEV_THROTTLING=n
CONFIG_BLK_WBT=y

#
# File systems
#
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_EXT4_FS_POSIX_ACL=y
